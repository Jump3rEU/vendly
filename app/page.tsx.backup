            <div class
                onClick={() => setShowSwipeMode(true)} 
                size="lg" 
                variant="secondary"
                className="flex items-center gap-2"
              >
                <Zap className="w-5 h-5" />
                Zkusit Swipe mód" size="lg" variant="primary">
